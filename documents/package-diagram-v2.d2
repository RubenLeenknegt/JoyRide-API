# Package diagram (excludes empty folders)
# Render: d2 documents/package-diagram-v2.d2 -o documents

style: { fill: "#ffffff" }

backend: {
  label: "leafcar.backend (Ktor app)"

  application: {
    label: "Application\n- Application.kt\n- DatabaseConfig.kt\n- DatabaseConnection.kt"
  }

  controller: {
    label: "controller\n- AuthController.kt\n- UserController.kt\n- CarController.kt\n- ReservationController.kt\n- AvailabilitiesController.kt\n- RidesController.kt\n- PhotosController.kt\n- BonusPointscontroller.kt"
  }

  services: {
    label: "services\n- Auth.kt\n- CarService.kt\n- JwtConfig.kt"
  }

  repository: {
    label: "repository\n- SharedRepository.kt\n- UserRepository.kt\n- CarRepository.kt\n- ReservationRepository.kt\n- AvailabilitiesRepository.kt\n- RidesRepository.kt\n- PhotoRepository.kt\n- BonusPointsRepository.kt"
  }

  mappers: {
    label: "mappers\n- CarMapper.kt\n- UserMapper.kt"
  }

  dto: {
    label: "dto\nrequest: CarCreateOrUpdateRequest.kt, CarLocationRequest.kt, RegisterRequest.kt, BonusPointsCreate.kt, LoginRequest.kt\nresponse: LoginResponse.kt\nUserDto.kt"
  }

  domain: {
    label: "domain\n- Car.kt, User.kt, Reservation.kt, Availability.kt, Ride.kt, Photo.kt, BonusPoints.kt, Enums.kt\n- auth/UserCredentials.kt"
  }

  dao: {
    label: "dao (Exposed)\n- UsersTable/UserEntity\n- CarsTable/CarEntity\n- PhotosTable/PhotosEntity\n- ReservationsTable/ReservationEntity\n- AvailabilitiesTable/AvailabilitiesEntity\n- RidesTable/RideEntity\n- BonusPointsTable/BonusPointsEntity"
  }
}

# Dependencies inside backend
backend.application -> backend.controller: "routes"
backend.controller -> backend.services: "business ops" { style: {stroke-dash: 6} }
backend.controller -> backend.repository: "calls repos"
backend.controller -> backend.dto: "uses DTOs"
backend.controller -> backend.domain: "produces domain" { style: {stroke-dash: 6} }

backend.services -> backend.repository: "data access"
backend.services -> backend.domain: "logic on domain"
backend.services -> backend.dto: "maps auth/login"

backend.repository -> backend.dao: "CRUD via Exposed"
backend.repository -> backend.domain: "returns domain"
backend.repository -> backend.mappers: "maps entity⇄domain/DTO"

backend.mappers -> backend.dao: "ResultRow, Entities"
backend.mappers -> backend.domain: "Car, Enums, User"
backend.mappers -> backend.dto: "Car DTOs, User DTOs"

backend.dao -> backend.domain: "IDs/enums types" { style: {stroke-dash: 6} }
