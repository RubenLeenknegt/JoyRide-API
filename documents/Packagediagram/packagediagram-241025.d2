# // Package diagram for fantastic-lamp backend (Kotlin/Ktor)
# // Render with: d2 documents/package-diagram-v1.d2 -o documents
# // Or use https: //play.d2lang.com and paste this file.

style: {
  fill: "#ffffff"
}

# legend: {
#   label: "Legend\nSolid arrow = typical dependency\nDashed arrow = optional/occasional dependency"
# }

project: {
  label: "fantastic-lamp"

  backend: {
    label: "backend/src/main/kotlin/leafcar/backend"

    application: {
      label: "Application & Bootstrapping\n- Application.kt\n- DatabaseConfig.kt\n- DatabaseConnection.kt"
    }

    controller: {
      label: "controller\n- AuthController.kt\n- UserController.kt\n- CarController.kt\n- ReservationController.kt\n- AvailabilitiesController.kt\n- RidesController.kt\n- PhotosController.kt\n- BonusPointscontroller.kt"
    }

    service: {
      label: "services\n- AuthService.kt\n- CarService.kt\n- JwtConfig.kt\n- MockDataGeneration.kt"
    }

    repository: {
      label: "repository\n- SharedRepository.kt\n- UserRepository.kt\n- CarRepository.kt\n- ReservationRepository.kt\n- AvailabilitiesRepository.kt\n- RidesRepository.kt\n- PhotoRepository.kt\n- BonusPointsRepository.kt\n- UserUpdateResult.kt"
    }

    mappers: {
      label: "mappers\n- CarMapper.kt\n- UserMapper.kt"
    }

    dto: {
      label: "dto\nrequest:\n- CarCreateOrUpdateRequest.kt\n- CarLocationRequest.kt\n- CarCpkDataRequest.kt\n- CarTcoDataRequest.kt\n- RegisterRequest.kt\n- LoginRequest.kt\n- BonusPointsCreate.kt\n- AccountModifyRequest.kt\n\nresponse:\n- LoginResponse.kt\n- CarCpkDataResponse.kt\n- CarTcoDataResponse.kt\n\n- UserDto.kt"
    }

    domain: {
      label: "domain\n- Car.kt\n- User.kt\n- Reservation.kt\n- Availability.kt\n- Ride.kt\n- Photo.kt\n- BonusPoints.kt\n- Enums.kt\n\nauth:\n- UserCredentials.kt"
    }

    dao: {
      label: "dao (Exposed)\n- Entity & Table classes\n  • CarEntity/CarsTable\n  • UserEntity/UsersTable\n  • PhotosEntity/PhotosTable\n  • ReservationEntity/ReservationsTable\n  • AvailabilitiesEntity/AvailabilitiesTable\n  • RideEntity/RidesTable\n  • BonusPointsEntity/BonusPointsTable"
    }
  }

  tests: {
    label: "backend/src/test\n- CarControllerTest.kt\n- http requests"
  }

  db_init: {
    label: "db-init\n- init.sql (schema)\n- test-queries.txt"
  }

  docs: {
    label: "documents\n- Class diagrams (.d2/.png)\n- Package diagram (this)"
  }
}

# // Dependencies within the backend
project.backend.application -> project.backend.controller: "wires routes"
project.backend.application -> project.db_init: "connects to DB defined externally" {
  style: {stroke-dash: 6}
}

project.backend.controller -> project.backend.service: "business ops" {
  style: {stroke-dash: 6}
}
project.backend.controller -> project.backend.repository: "calls repos"
project.backend.controller -> project.backend.dto: "uses request models"
project.backend.controller -> project.backend.domain: "returns domain models" {
  style: {stroke-dash: 6}
}

project.backend.service -> project.backend.repository: "data access"
project.backend.service -> project.backend.domain: "business logic on domain"

project.backend.repository -> project.backend.dao: "CRUD via Exposed"
project.backend.repository -> project.backend.mappers: "map entity ⇄ domain/dto"
project.backend.repository -> project.backend.domain: "returns domain"

project.backend.mappers -> project.backend.dao: "CarEntity, UserEntity, ResultRow"
project.backend.mappers -> project.backend.domain: "Car, User, Enums"
project.backend.mappers -> project.backend.dto: "Car DTOs, User DTOs"

project.backend.dao -> project.backend.domain: "IDs/enums typed to domain" {
  style: {stroke-dash: 6}
}

# // Tests hit controllers and thus the full stack
project.tests -> project.backend.controller: "integration-style tests" {
  style: {stroke-dash: 6}
}

# // Notes
note_exposed: {
  label: "DAO uses JetBrains Exposed ORM (Database.connect via Hikari)"
}
project.backend.dao -> note_exposed

# // Docker and Frontend context additions
project.docker: {
  label: "docker\n- backend/Dockerfile\n- docker-compose.local.yml\n- docker-compose.acc.yml\n- docker-compose.prod.yml"
}

project.frontend: {
  label: "frontend\n- (coming soon..)"
}

# // Docker relationships
project.docker -> project.backend: "builds image and orchestrates services"
project.docker -> project.db_init: "uses/mounts init.sql for DB" {style: {stroke-dash: 6}}
