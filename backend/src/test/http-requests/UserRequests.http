@baseUrl = http://localhost:8081

### Register new user
POST {{baseUrl}}/auth/users/register
Content-Type: application/json

{
  "emailAddress": "JohnJackson@hotmail.com",
  "firstName": "Peter",
  "lastName": "Jackson",
  "birthDate": "1998-01-05",
  "userType": "OWNER",
  "bankAccount": "ojghbjsk234820348",
  "bankAccountName": "HR P Jackson",
  "password": "Ditismijnwachtwoord"
}

> {%
    client.global.set("access_token", response.body.accessToken);
    client.global.set("user_id", response.body.user.id);
%}

### Login
POST {{baseUrl}}/auth/users/login
Content-Type: application/json

{
  "emailAddress": "JohnJackson@hotmail.com",
  "password": "Ditismijnwachtwoord"
}

> {%
    client.global.set("access_token", response.body.accessToken);
    client.global.set("user_id", response.body.user.id);
%}

### Refresh token
POST {{baseUrl}}/refresh

> {%
    client.global.set("access_token", response.body.accessToken);
%}

### Update first name
PUT {{baseUrl}}/users/account/{{user_id}}/firstName
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "value": "Halloooo"
}

### Autologin
POST {{baseUrl}}/auth/autologin
Authorization: Bearer {{access_token}}

### Get owned cars
GET {{baseUrl}}/cars/owned
Authorization: Bearer {{access_token}}
Accept: application/json

> {%
    if (response.body.length > 0) {
        client.global.set("car_id", response.body[0].id);
    }
%}

### Delete user account
DELETE {{baseUrl}}/users/account/{{user_id}}
Authorization: Bearer {{access_token}}
