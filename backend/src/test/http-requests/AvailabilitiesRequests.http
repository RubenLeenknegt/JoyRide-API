@baseUrl = http://localhost:8081

### Register new user
POST {{baseUrl}}/auth/users/register
Content-Type: application/json

{
  "emailAddress": "PaulJackson@hotmail.com",
  "firstName": "Paul",
  "lastName": "Jackson",
  "birthDate": "1993-02-05",
  "userType": "OWNER",
  "bankAccount": "ojghbjsk234820348",
  "bankAccountName": "HR P Jackson",
  "password": "Ditismijnwachtwoord"
}

> {%
    client.global.set("access_token", response.body.accessToken);
    client.global.set("user_id", response.body.user.id)
%}

### Log in to api and key jwt
POST {{baseUrl}}/auth/users/login
Content-Type: application/json

{
  "emailAddress": "PaulJackson@hotmail.com",
  "password": "Ditismijnwachtwoord"
}
> {%
    client.global.set("access_token", response.body.accessToken);
    client.global.set("user_id", response.body.user.id)

%}

### Get all availabilities
GET {{baseUrl}}/availabilities
Authorization: Bearer {{access_token}}
Accept: application/json

### Get availability by ID
GET {{baseUrl}}/availabilities/9d785f64-5717-4562-b3fc-2c963f66d004
Authorization: Bearer {{access_token}}
Accept: application/json

### Get availability by carId
GET {{baseUrl}}/availabilities/car/4b285f64-5717-4562-b3fc-2c963f66b001
Authorization: Bearer {{access_token}}
Accept: application/json

### Get available availabilities
GET {{baseUrl}}/availabilities/available
Authorization: Bearer {{access_token}}
Accept: application/json

### Get available availabilities with timeslot filter
GET {{baseUrl}}/availabilities/available?startDate=2025-10-01T06:00&endDate=2025-10-15T18:00
Authorization: Bearer {{access_token}}
Accept: application/json

### Get available availabilities filterd by carId
GET {{baseUrl}}/availabilities/available/car/4b285f64-5717-4562-b3fc-2c963f66b005
Authorization: Bearer {{access_token}}
Accept: application/json

### Create a new availability
POST {{baseUrl}}/availabilities
Authorization: Bearer {{access_token}}
Content-Type: application/json
Accept: application/json

{
  "carId": "7f57db8e-9684-4257-92fe-5d942e4e8cd2",
  "startDate": "2025-10-22T08:00:00",
  "endDate": "2025-10-22T12:00:00"
}


### Update an existing availability
PUT {{baseUrl}}/availabilities/9d785f64-5717-4562-b3fc-2c963f66d004
Authorization: Bearer {{access_token}}
Content-Type: application/json
Accept: application/json

{
  "carId": "7f57db8e-9684-4257-92fe-5d942e4e8cd2",
  "startDate": "2025-10-23T09:00:00",
  "endDate": "2025-10-23T15:00:00"
}

### Delete an availability
DELETE {{baseUrl}}/availabilities/9d785f64-5717-4562-b3fc-2c963f66d004
Authorization: Bearer {{access_token}}
Accept: application/json
