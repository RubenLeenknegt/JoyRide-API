@baseUrl = http://localhost:8081

### Log in
POST {{baseUrl}}/auth/users/login
Content-Type: application/json

{
  "emailAddress": "eva.degroot@gmail.com",
  "password": "hash11"
}

> {%
    client.global.set("access_token", response.body.accessToken);
    client.global.set("user_id", response.body.user.id);
%}

### Get all rides
GET {{baseUrl}}/rides
Authorization: Bearer {{access_token}}
Accept: application/json

> {%
    if (response.body.length > 0) {
        client.global.set("ride_id", response.body[0].id);
        client.global.set("reservation_id", response.body[0].reservationId);
    }
%}

### Get ride by id (dynamic)
GET {{baseUrl}}/rides/{{ride_id}}
Authorization: Bearer {{access_token}}
Accept: application/json

### Get rides by reservationId (dynamic)
GET {{baseUrl}}/rides/reservation/{{reservation_id}}
Authorization: Bearer {{access_token}}
Accept: application/json

### Create a new ride (dynamic reservationId)
POST {{baseUrl}}/rides
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "startX": 52.3702,
  "startY": 4.8952,
  "endX": 52.3710,
  "endY": 4.8965,
  "length": 1500,
  "duration": 600,
  "reservationId": "{{reservation_id}}",
  "dateTimeStart": "2025-12-22T13:15",
  "dateTimeEnd": "2025-12-22T15:15",
  "distanceTravelled": 156
}

> {%
    client.global.set("created_ride_id", response.body.id);
%}

### Delete the newly created ride
DELETE {{baseUrl}}/rides/{{created_ride_id}}
Authorization: Bearer {{access_token}}
Accept: application/json

### Get ridelist for user (dynamic)
GET {{baseUrl}}/rides/ridelist/user/{{user_id}}
Authorization: Bearer {{access_token}}
Accept: application/json
