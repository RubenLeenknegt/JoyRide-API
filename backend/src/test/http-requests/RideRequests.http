@baseUrl = http://localhost:8081

### Register new user
POST {{baseUrl}}/auth/users/register
Content-Type: application/json

{
  "emailAddress": "HenkKlaasen@hotmail.com",
  "firstName": "Henk",
  "lastName": "Klaasen",
  "birthDate": "1998-01-05",
  "userType": "OWNER",
  "bankAccount": "ojghbjsk234820348",
  "bankAccountName": "HR P Jackson",
  "password": "Ditismijnwachtwoord"
}

> {%
    client.global.set("access_token", response.body.accessToken);
    client.global.set("user_id", response.body.user.id)
%}

### Log in to api and key jwt
POST {{baseUrl}}/auth/users/login
Content-Type: application/json

{
  "emailAddress": "HenkKlaasen@hotmail.com",
  "password": "Ditismijnwachtwoord"
}
> {%
    client.global.set("access_token", response.body.accessToken);
    client.global.set("user_id", response.body.user.id)

%}

### Get all rides
GET {{baseUrl}}/rides
Authorization: Bearer {{access_token}}
Accept: application/json

### Get ride by id
GET {{baseUrl}}/rides/feee78cc-2d27-4268-808a-d9af29c2ca19
Authorization: Bearer {{access_token}}
Accept: application/json

### Get rides by reservationId
GET {{baseUrl}}/rides/reservation/3ad1d4bf-aa08-4ea0-98ca-d6e01933323b
Authorization: Bearer {{access_token}}
Accept: application/json

### Create a new ride
POST {{baseUrl}}/rides
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "startX": 52.3702,
  "startY": 4.8952,
  "endX": 52.3710,
  "endY": 4.8965,
  "length": 1500,
  "duration": 600,
  "reservationId": "3ad1d4bf-aa08-4ea0-98ca-d6e01933323b",
  "dateTimeStart": "2025-12-22T13:15",
  "dateTimeEnd": "2025-12-22T15:15",
  "distanceTravelled": 156
}

### Delete a ride
DELETE {{baseUrl}}/rides/97695d40-aa4c-4130-9a5c-bb90121e7104
Authorization: Bearer {{access_token}}
Accept: application/json

### Get ridelist
GET {{baseUrl}}/rides/ridelist/user/1ebafbba-ee85-48eb-837f-f48602a8d401
Authorization: Bearer {{access_token}}
Accept: application/json