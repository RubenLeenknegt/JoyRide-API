@baseUrl = http://localhost:8081

### Register new user
POST {{baseUrl}}/auth/users/register
Content-Type: application/json

{
  "emailAddress": "PeterJackson1@hotmail.com",
  "firstName": "Peter",
  "lastName": "Jackson",
  "birthDate": "1998-01-05",
  "userType": "OWNER",
  "bankAccount": "ojghbjsk234820348",
  "bankAccountName": "HR P Jackson",
  "vehicleLocation": "0342309480",
  "password": "Ditismijnwachtwoord"
}

> {%
    client.global.set("access_token", response.body.accessToken);
    client.global.set("user_id", response.body.user.id);
%}

### Get all cars
GET {{baseUrl}}/cars
Accept: application/json
Authorization: Bearer {{access_token}}

> {%
    if (response.body.length > 0) {
        client.global.set("car_id", response.body[0].id);
    }
%}

### Get car by id (dynamic)
GET {{baseUrl}}/cars/id/{{car_id}}
Accept: application/json
Authorization: Bearer {{access_token}}

### Get car locations
GET {{baseUrl}}/cars/location
Accept: application/json
Authorization: Bearer {{access_token}}

### Create a new car
POST {{baseUrl}}/cars
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "brand": "Toyota",
  "model": "Corolla",
  "buildYear": 2015,
  "transmissionType": "AUTOMATIC",
  "color": "WHITE",
  "fuelType": "ICE",
  "length": 1,
  "width": 1750,
  "seats": 2,
  "isofixCompatible": true,
  "phoneMount": true,
  "luggageSpace": 350.0,
  "parkingSensors": true,
  "locationX": 52.3702,
  "locationY": 4.8952,
  "licensePlate": "12-AB-CD",
  "pricePerDay": 65.0,
  "purchasePrice": 15000.0,
  "residualValue": 10000.0,
  "usageYears": 8,
  "annualKm": 12000,
  "energyCostPerKm": 0.08,
  "maintenanceCostPerKm": 0.04,
  "averageConsumption": 20
}

> {%
    client.global.set("created_car_id", response.body.id);
%}

### Update created car
PUT {{baseUrl}}/cars/id/{{created_car_id}}
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "ownerId": "{{user_id}}",
  "brand": "Land Rover",
  "model": "Series 3",
  "buildYear": 1975,
  "transmissionType": "MANUAL",
  "color": "GREEN",
  "fuelType": "ICE",
  "length": 3880,
  "width": 1600,
  "seats": 12,
  "isofixCompatible": false,
  "phoneMount": false,
  "luggageSpace": 200.0,
  "parkingSensors": false,
  "locationX": 51.5652,
  "locationY": 3.5912,
  "licensePlate": "98-YA-67",
  "pricePerDay": 80.0,
  "purchasePrice": 25000.0,
  "residualValue": 15000.0,
  "usageYears": 5,
  "annualKm": 15000,
  "energyCostPerKm": 0.10,
  "maintenanceCostPerKm": 0.05,
  "averageConsumption": 20
}

### Optional: Get filtered cars
GET {{baseUrl}}/cars?phonemount=false&color=GREY&color=RED
Accept: application/json
Authorization: Bearer {{access_token}}

### Get TCO (dynamic)
GET {{baseUrl}}/cars/tco/{{created_car_id}}
Accept: application/json
Authorization: Bearer {{access_token}}

### Get CPK (dynamic)
GET {{baseUrl}}/cars/cpk/{{created_car_id}}
Accept: application/json
Authorization: Bearer {{access_token}}

### Get carlist
GET {{baseUrl}}/cars/carlist
Accept: application/json
Authorization: Bearer {{access_token}}

### Delete created car
DELETE {{baseUrl}}/cars/id/{{created_car_id}}
Accept: application/json
Authorization: Bearer {{access_token}}
