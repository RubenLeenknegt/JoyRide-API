<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Silence Exposed SQL debug messages -->
    <logger name="org.jetbrains.exposed" level="WARN"/>
    <logger name="org.jetbrains.exposed.sql" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="WARN"/>
    <logger name="com.zaxxer.hikari.pool" level="WARN"/>
    <logger name="com.zaxxer.hikari.HikariConfig" level="WARN"/>
    <logger name="qos logback" level="WARN"/>


    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
